# Copy to .env and fill in. ChronoLens reads SigNoz over MCP/REST.
SIGNOZ_URL=http://localhost:8080
SIGNOZ_API_KEY=
SIGNOZ_MCP_URL=http://localhost:8000/mcp

# Where the demo store exposes its admin levers (fault injection + reversible fixes)
DEMO_STORE_URL=http://localhost:8090

# LLM for the plain-English explanations: none | openai | bedrock
LLM_PROVIDER=none

# p99 latency SLO for the watched service, in milliseconds
P99_SLO_MS=500
