# Copy to .env and fill in. ChronoLens reads SigNoz over MCP/REST.
SIGNOZ_URL=http://localhost:8080
SIGNOZ_API_KEY=
SIGNOZ_MCP_URL=http://localhost:8000/mcp

# Where the demo store exposes its admin levers (fault injection + reversible fixes)
DEMO_STORE_URL=http://localhost:8090

# p99 latency SLO for the watched service, in milliseconds
P99_SLO_MS=500

# --- pluggable LLM for plain-English explanations (all optional) ---
# none | openai | bedrock | gemini  (runs fine with none — rule-based fallback)
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
BEDROCK_MODEL=anthropic.claude-3-haiku-20240307-v1:0
AWS_REGION=us-east-1

# --- cost model: turn capacity units into dollars ---
COST_PER_UNIT_HR=0.65

# --- governance / trust ladder: suggest | earn | auto ---
CHRONOLENS_AUTONOMY=auto
CHRONOLENS_TRUST_MIN_SAVES=3

# --- anti-flap guardrails ---
CHRONOLENS_MIN_DWELL_S=20
CHRONOLENS_MAX_CAPACITY=12

# --- confidence guard (ignore noise) ---
CHRONOLENS_MIN_SLOPE=3.0
CHRONOLENS_MIN_SAMPLES=4

# --- notifications: Slack incoming webhook or any {"text": ...} webhook ---
CHRONOLENS_WEBHOOK_URL=
